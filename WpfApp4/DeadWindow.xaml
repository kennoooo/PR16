<Window x:Class="WpfApp.DeadWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp4"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="900"
      Title="Dead">
    <Grid Background="Black">
        <StackPanel Margin="10" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Margin="10" Text="Вы умерли!" FontSize="60" FontWeight="Bold" Foreground="Red"/>
            <Button Margin="10" FontWeight="Bold"  Content="Нажмите чтоб играть снова" FontSize="20" Width="300" Height="100" Click="Back_Click" BorderBrush="red" Background="DarkGray"/>
            <Button Margin="10" FontWeight="Bold"  Content="Выйти" FontSize="20" Width="300" Height="100" Click="Back_Click2" BorderBrush="red" Background="DarkGray"/>
        </StackPanel>
    </Grid>
</Window>
